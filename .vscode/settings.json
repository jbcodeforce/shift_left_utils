{
  // --- Cursor: local LLM (Osaurus) for offline/airplane use ---
  // Use Cursor Settings → Models → OpenAI API Keys → set Override Base URL to:
  //   http://127.0.0.1:1337/v1
  // and API key to any placeholder (e.g. not-needed). Then pick a model exposed by Osaurus.
  // See docs/coding/cursor_local_llm.md for full steps.
  "cursor.openai.baseUrl": "http://127.0.0.1:1337/v1",

  // Python-specific settings
  "python.analysis.extraPaths": [
    "src/shift_left"
  ],
  "python.defaultInterpreterPath": "${workspaceFolder}/src/shift_left/.venv/bin/python",

  // Editor settings to prevent tab/space issues
  "editor.insertSpaces": false,
  "editor.tabSize": 4,
  "editor.detectIndentation": false,

  // Python-specific indentation
  "[python]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.indentSize": 4,
    "editor.detectIndentation": false,
    "editor.formatOnSave": false
  },

  // Trim trailing whitespace
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // Show whitespace characters to catch tabs
  "editor.renderWhitespace": "boundary",

  // File associations
  "files.associations": {
    "*.sql": "sql"
  },

  // Additional language settings
  "[sql]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[json]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[markdown]": {
    "files.trimTrailingWhitespace": false
},
"cursorpyright.analysis.extraPaths": [
	"src/shift_left"
]
}
