{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
		{"name":"Python Debugger: Current File","type":"debugpy","request":"launch","program":"${file}","console":"integratedTerminal"},
        {
            "name": "SL Python Debugger: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "CONFIG_FILE": "${fileWorkspaceFolder}/src/shift_left/tests/config.yaml",
                "PYTHONPATH": "${fileWorkspaceFolder}/src/shift_left:${fileWorkspaceFolder}/src/shift_left/tests"
              },
               "python": "${workspaceFolder}/src/shift_left/.venv/bin/python"
        },
        {
            "name": "SL Python Debugger: pytest current file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/shift_left",
            "justMyCode": false,
            "env": {
                "CONFIG_FILE": "${workspaceFolder}/src/shift_left/tests/config.yaml",
                "PYTHONPATH": "${workspaceFolder}/src/shift_left:${workspaceFolder}/src/shift_left/tests"
            },
            "python": "${workspaceFolder}/src/shift_left/.venv/bin/python"
        },
        {
         "name": "SL Python IT Debugger: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "preLaunchTask": "verify_env_file",
            "envFile": "${workspaceFolder}/../flink_project_demos/customer_360/c360_flink_processing/.env",
            "env": {
                // Note: Variables from envFile are loaded first, then these override/add to them
                // The Python script also loads .env at module level to ensure variables are available
                "PYTHONPATH": "${fileWorkspaceFolder}/src/shift_left:${fileWorkspaceFolder}/src/shift_left/tests",
				"SL_LLM_BASE_URL" : "http://localhost:1337/v1",
				"SL_LLM_MODEL" : "qwen3-coder-30b-a3b-instruct-mlx-4bit",
				"SL_LLM_API_KEY" : "llm_test_key",
				"SL_RAG_ENABLED" : "1",
				"SL_RAG_INDEX_PATH" : "${workspaceFolder}/../flink_project_demos/ksql_tutorial/rag_index"
              },
               "python": "${workspaceFolder}/src/shift_left/.venv/bin/python"
        },
    ]
}
